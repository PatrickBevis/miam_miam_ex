{% extends 'base.html.twig' %}

{% block title %}Ingredient{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-100 py-10">
    <div class="w-full max-w-2xl  shadow-lg rounded-lg p-8">

        <h1 class="text-2xl font-bold mb-6 text-center">
            Ingredient
        </h1>

        <table class="w-full border border-gray-200 rounded-lg overflow-hidden">
            <tbody class="divide-y divide-gray-200">
                <tr class="bg-gray-50">
                    <th class="px-4 py-3 text-left text-gray-600 font-medium w-1/3">
                        Name
                    </th>
                    <td class="px-4 py-3 text-gray-800">
                        {{ ingredient.name }}
                    </td>
                </tr>
                <tr>
                    <th class="px-4 py-3 text-left text-gray-600 font-medium">
                        Price
                    </th>
                    <td class="px-4 py-3 text-gray-800">
                        {{ ingredient.price }} €
                    </td>
                </tr>
                <tr class="bg-gray-50">
                    <th class="px-4 py-3 text-left text-gray-600 font-medium">
                        Created at
                    </th>
                    <td class="px-4 py-3 text-gray-800">
                        {{ ingredient.createdAt ? ingredient.createdAt|date('d/m/Y') : '' }}
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-8 flex justify-between items-center">
            <a href="{{ path('app_ingredient_index') }}"
               class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition">
                ← Back
            </a>

            <div class="flex gap-2">
                <a href="{{ path('app_ingredient_edit', {'id': ingredient.id}) }}"
                   class="px-4 py-2 bg-red-600 text-white rounded hover:bg-blue-700 transition">
                    Edit
                </a>

                {{ include('ingredient/_delete_form.html.twig') }}
            </div>
        </div>

    </div>
</div>
{% endblock %}